# Copia este archivo a .env en el servidor o usa el generado por preparar-hostinger.bat
# Si la app va en el dominio principal, deja APP_URL vacio.
# Si la app va en una subcarpeta, por ejemplo /evaluator, usa APP_URL=evaluator

APP_NAME=Evaluator
APP_URL=
APP_TIMEZONE=Europe/Madrid
SESSION_NAME=evaluator_session

DB_DRIVER=mysql
DB_HOST=TU_DB_HOST
DB_PORT=3306
DB_DATABASE=TU_BASE_DE_DATOS
DB_USERNAME=TU_USUARIO_DB
DB_PASSWORD=TU_PASSWORD_DB
